#!/usr/bin/env zsh
set -euo pipefail

version=$(node -e 'const pkg = require("./package.json"); console.log(pkg.version || "0.0.0");')

show_help() {
  cat <<'USAGE'
splatter - local iPhone video to Gaussian Splat publish pipeline

Usage:
  splatter <command> [args]
  splatter --help
  splatter --version

Commands:
  check                                      Check local tools
  validate                                   Validate deployable public viewer
  capture <video> <name> [fps]               Extract frames, run COLMAP, analyze
  analyze <name>                             Analyze COLMAP sparse models
  train <name> [iters] [downscale] [ply]     Run OpenSplat
  select-frames <src> <dst> [max-frames]     Select sharp, diverse capture frames
  frame-quality <capture> [max-sample]        Score frame sharpness, exposure, and motion
  convert <input> [output]                   Convert scene formats, defaults to SOG
  stage <scene> [title]                      Stage scene into public/assets
  quality-report <name> [scene]              Report capture, COLMAP, and scene quality signals
  compare-holdout <reference> <render> [json]
                                             Compute holdout PSNR/SSIM metrics
  quality-stage <ply> <title> [preset]       Convert and stage progressive quality assets
  quality-sweep <video> <base-name> [title]  Plan or run quality experiment matrix
  segment-sweep <video> <base-name>          Plan or run segment quality candidates
  segment-sweep-fine <video> <base-name>     Plan or run 20s/5s fine segment candidates
  matcher-sweep <capture> [base-name]        Plan or run COLMAP matcher candidates
  rank-captures <capture-prefix>             Rank COLMAP candidates by structure signals
  colmap-gate <capture>                      Score COLMAP structure before training
  select-checkpoint <ply-prefix>             Pick the best finite OpenSplat checkpoint
  mask-frames <capture>                      Generate optional masks for dynamic objects
  depth-priors <capture>                     Generate optional monocular depth priors
  depth-report <capture>                     Report depth prior coverage
  mesh-validate <ply>                        Plan optional surface/mesh validation
  mesh-simplify <input> <output> [max-faces]  Write a lightweight cleaned mesh PLY
  mesh-largest-component <input> <output>    Keep only the largest connected mesh component
  voxel-grid <points> <json> <ply> [res] [bbox] [min] [dilate]
                                             Build a 3D occupancy voxel grid
  voxel-free-space <points> <voxels.json> <camera-source> <summary.json> <free.ply> <navigable.ply> [max-rays] [max-free]
                                             Build camera-carved free/navigable voxel masks
  voxel-segment <voxels.json> <free.ply> <navigable.ply> <summary.json> <semantic.ply>
                                             Fuse voxel layers into semantic voxel labels
  voxel-stage-primary [res] [min] [dilate]   Stage occupancy voxel grids for primary OpenMVS scenes
  voxel-stage-free-space-primary [max-rays] [max-free]
                                             Stage free/navigable voxel masks for primary OpenMVS scenes
  voxel-stage-semantics                      Stage semantic voxel labels for primary OpenMVS scenes
  sam-mask-voxel-segment <voxels.json> <colmap-sparse> <mask-dir> <summary.json> <semantic.ply> [min-votes]
                                             Project SAM/SAM3 masks into occupied voxel labels
  sam-select-mask-frames <capture> [max]      Select representative frames for SAM/SAM3 masking
  sam-prepare-mask-workspace [out]            Package selected frames for SAM/SAM3 masking
  sam-auto-masks [--check] <capture> [max-frames] [label]
                                             Generate real SAM masks from selected capture frames
  sam-generate-mask-assets <capture> [max-frames] [label]
                                             Generate SAM-compatible bootstrap mask assets
  sam-stage-voxel-semantics [min-votes]      Stage SAM-mask voxel labels for primary OpenMVS scenes
  voxel-improve-primary [res-list]           Sweep and stage best primary voxel grids
  surface-reconstruct <capture> [model]      Run COLMAP dense depth, fusion, and mesh
  openmvs-batch [input-dir]                  Run OpenMVS for best capture per input and stage mesh results
  openmvs-sweep <capture> [model]            Run OpenMVS quality variants for one capture
  openmvs-sweep-all [input-dir]              Sweep all input captures, apply winners, and restage
  openmvs-validate                           Validate staged OpenMVS mesh assets and camera framing
  pipeline-manifest [input-dir] [output]      Write manifest-driven pipeline status
  pipeline-run [input-dir]                    Orchestrate primary target staging from manifest
  trellis2-generate [--check] <image> [out]   Plan or run optional TRELLIS.2 generation
  sam3d-reconstruct [--check] <image> <mask-dir> [out]
                                             Plan or run optional SAM 3D object reconstruction
  sam3d-multi-gif [--check] [image] [out]     Run SAM 3D multi-object notebook flow to PLY/GIF
  sam3d-mac-port-check                       Probe local Mac SAM 3D port blockers
  viewer-qa                                  Validate viewer scene assets and point-cloud wiring
  mlx-smoke [steps] [gaussians]              Check local gsplat-mlx viability
  mlx-diagnose [args]                        Diagnose gsplat-mlx NaN sources
  mlx-frame-quality <capture> [max-sample]   Use MLX for capture quality aggregation when available
  publish <video> <name> [fps] [iters] [downscale] [title] [stage|no-stage]
                                             Run capture/train/convert/stage pipeline
  serve                                      Serve public viewer on localhost:8080

Examples:
  splatter publish input/capture.mov my-capture 2 2000 4 "My Capture"
  splatter publish input/IMG_9142.MOV img-9142-fps2 2 5 4 "Smoke" no-stage
USAGE
}

if (( $# == 0 )); then
  show_help
  exit 0
fi

case "$1" in
  -h|--help|help)
    show_help
    ;;
  -v|--version|version)
    echo "$version"
    ;;
  check)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter check" >&2
      exit 1
    fi
    scripts/check_tools.sh
    ;;
  validate)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter validate" >&2
      exit 1
    fi
    scripts/validate_public.sh
    ;;
  capture)
    shift
    scripts/process_capture.sh "$@"
    ;;
  analyze)
    shift
    scripts/analyze_colmap.sh "$@"
    ;;
  train)
    shift
    scripts/run_opensplat.sh "$@"
    ;;
  select-frames)
    shift
    scripts/select_frames.sh "$@"
    ;;
  frame-quality)
    shift
    scripts/frame_quality.py "$@"
    ;;
  convert)
    shift
    scripts/convert_scene.sh "$@"
    ;;
  stage)
    shift
    scripts/prepare_scene.sh "$@"
    ;;
  quality-report)
    shift
    scripts/report_quality.sh "$@"
    ;;
  compare-holdout)
    shift
    scripts/compare_holdout.sh "$@"
    ;;
  quality-stage)
    shift
    scripts/stage_quality_scene.sh "$@"
    ;;
  quality-sweep)
    shift
    scripts/sweep_quality.sh "$@"
    ;;
  segment-sweep)
    shift
    scripts/sweep_segments.sh "$@"
    ;;
  segment-sweep-fine)
    shift
    SPLAT_SEGMENT_WINDOW="${SPLAT_SEGMENT_WINDOW:-20}" SPLAT_SEGMENT_STRIDE="${SPLAT_SEGMENT_STRIDE:-5}" scripts/sweep_segments.sh "$@"
    ;;
  matcher-sweep)
    shift
    scripts/sweep_matchers.sh "$@"
    ;;
  rank-captures)
    shift
    scripts/rank_captures.sh "$@"
    ;;
  colmap-gate)
    shift
    scripts/colmap_gate.sh "$@"
    ;;
  select-checkpoint)
    shift
    scripts/select_checkpoint.sh "$@"
    ;;
  mask-frames)
    shift
    scripts/mask_frames.sh "$@"
    ;;
  depth-priors)
    shift
    scripts/depth_priors.sh "$@"
    ;;
  depth-report)
    shift
    scripts/depth_report.sh "$@"
    ;;
  mesh-validate)
    shift
    scripts/mesh_validate.sh "$@"
    ;;
  mesh-simplify)
    shift
    scripts/mesh_simplify.py "$@"
    ;;
  mesh-largest-component)
    shift
    scripts/mesh_largest_component.py "$@"
    ;;
  voxel-grid)
    shift
    scripts/voxel_grid.py "$@"
    ;;
  voxel-free-space)
    shift
    scripts/voxel_free_space.py "$@"
    ;;
  voxel-segment)
    shift
    scripts/voxel_semantic_segment.py "$@"
    ;;
  voxel-stage-primary)
    shift
    if (( $# > 3 )); then
      echo "Usage: splatter voxel-stage-primary [resolution] [min-count] [dilate]" >&2
      exit 1
    fi
    scripts/stage_voxel_grids.py "$@"
    ;;
  voxel-stage-free-space-primary)
    shift
    if (( $# > 2 )); then
      echo "Usage: splatter voxel-stage-free-space-primary [max-rays] [max-free]" >&2
      exit 1
    fi
    scripts/stage_free_space_grids.py "$@"
    ;;
  voxel-stage-semantics)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter voxel-stage-semantics" >&2
      exit 1
    fi
    scripts/stage_voxel_semantics.py
    ;;
  sam-mask-voxel-segment)
    shift
    scripts/sam_mask_voxel_project.py "$@"
    ;;
  sam-select-mask-frames)
    shift
    scripts/select_sam_mask_frames.py "$@"
    ;;
  sam-prepare-mask-workspace)
    shift
    if (( $# > 1 )); then
      echo "Usage: splatter sam-prepare-mask-workspace [output-dir]" >&2
      exit 1
    fi
    scripts/prepare_sam_mask_workspace.py "$@"
    ;;
  sam-auto-masks)
    shift
    if [[ -n "${SAM_MASK_PYTHON:-}" ]]; then
      "$SAM_MASK_PYTHON" scripts/sam_auto_masks.py "$@"
    elif [[ -x ".local/sam3d-mac-venv/bin/python" ]]; then
      .local/sam3d-mac-venv/bin/python scripts/sam_auto_masks.py "$@"
    else
      scripts/sam_auto_masks.py "$@"
    fi
    ;;
  sam-generate-mask-assets)
    shift
    scripts/generate_sam_mask_assets.py "$@"
    ;;
  sam-stage-voxel-semantics)
    shift
    if (( $# > 1 )); then
      echo "Usage: splatter sam-stage-voxel-semantics [min-votes]" >&2
      exit 1
    fi
    scripts/stage_sam_voxel_semantics.py "$@"
    ;;
  voxel-improve-primary)
    shift
    if (( $# > 1 )); then
      echo "Usage: splatter voxel-improve-primary [resolution-list]" >&2
      exit 1
    fi
    scripts/voxel_improve.py "$@"
    ;;
  surface-reconstruct)
    shift
    scripts/colmap_surface.sh "$@"
    ;;
  openmvs-batch)
    shift
    scripts/openmvs_batch.sh "$@"
    ;;
  openmvs-sweep)
    shift
    scripts/openmvs_sweep.py "$@"
    ;;
  openmvs-sweep-all)
    shift
    input_dir="${1:-input}"
    if (( $# > 1 )); then
      echo "Usage: splatter openmvs-sweep-all [input-dir]" >&2
      exit 1
    fi
    scripts/openmvs_sweep_all.py "$input_dir"
    ;;
  openmvs-validate)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter openmvs-validate" >&2
      exit 1
    fi
    scripts/openmvs_validate.py
    ;;
  pipeline-manifest)
    shift
    input_dir="${1:-input}"
    if (( $# > 2 )); then
      echo "Usage: splatter pipeline-manifest [input-dir] [output-json]" >&2
      exit 1
    fi
    if (( $# == 2 )); then
      scripts/pipeline_manifest.py "$input_dir" "$2"
    else
      scripts/pipeline_manifest.py "$input_dir"
    fi
    ;;
  pipeline-run)
    shift
    input_dir="${1:-input}"
    if (( $# > 1 )); then
      echo "Usage: splatter pipeline-run [input-dir]" >&2
      exit 1
    fi
    scripts/pipeline_run.py "$input_dir"
    ;;
  trellis2-generate)
    shift
    scripts/trellis2_adapter.py "$@"
    ;;
  sam3d-reconstruct)
    shift
    scripts/sam3d_adapter.py "$@"
    ;;
  sam3d-multi-gif)
    shift
    if [[ -n "${SAM3D_PYTHON:-}" ]]; then
      "$SAM3D_PYTHON" scripts/sam3d_multi_object_gif.py "$@"
    else
      scripts/sam3d_multi_object_gif.py "$@"
    fi
    ;;
  sam3d-mac-port-check)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter sam3d-mac-port-check" >&2
      exit 1
    fi
    scripts/sam3d_mac_port_check.py
    ;;
  viewer-qa)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter viewer-qa" >&2
      exit 1
    fi
    node scripts/viewer_qa.mjs
    ;;
  mlx-smoke)
    shift
    scripts/check_mlx_gsplat.sh "$@"
    ;;
  mlx-diagnose)
    shift
    scripts/diagnose_mlx_gsplat.sh "$@"
    ;;
  mlx-frame-quality)
    shift
    scripts/mlx_frame_quality.py "$@"
    ;;
  publish)
    shift
    scripts/process_publish.sh "$@"
    ;;
  serve)
    shift
    if (( $# != 0 )); then
      echo "Usage: splatter serve" >&2
      exit 1
    fi
    npm run serve
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "Run 'splatter --help' for usage." >&2
    exit 1
    ;;
esac
